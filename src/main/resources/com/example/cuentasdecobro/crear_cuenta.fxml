<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.cuentasdecobro.CrearCuentaController">
    <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
    <Label text="Crear Cuenta de Cobro"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <HBox spacing="10">
        <Label text="Número:" prefWidth="120"/>
        <TextField fx:id="txtNumero" promptText="Número de cuenta"/>
    </HBox>
    <HBox spacing="10">
        <Label text="Funcionario:" prefWidth="120"/>
        <TextField fx:id="txtFuncionario" promptText="Nombre del funcionario"/>
    </HBox>
    <HBox spacing="10">
        <Label text="Entidad:" prefWidth="120"/>
        <TextField fx:id="txtEntidad" promptText="Nombre de la entidad"/>
    </HBox>
    <HBox spacing="10">
        <Label text="Fecha:" prefWidth="120"/>
        <DatePicker fx:id="dpFecha"/>
    </HBox>
    <HBox spacing="10">
        <Label text="Valor:" prefWidth="120"/>
        <TextField fx:id="txtValor" promptText="Valor"/>
    </HBox>
    <HBox spacing="10">
        <Label text="Estado:" prefWidth="120"/>
        <ComboBox fx:id="cmbEstado" promptText="Seleccione estado"/>
    </HBox>
    <HBox spacing="10">
        <Button text="Guardar" onAction="#guardar"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Cancelar" onAction="#cancelar"/>
    </HBox>
</VBox>
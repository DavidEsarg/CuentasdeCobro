<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane"
            prefHeight="580.0" prefWidth="860.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cuentasdecobro.VistaPrincipalController">
    <left>
        <VBox minWidth="160.0" spacing="6.0"
              style="-fx-background-color: #1A3A5C;">
            <padding><Insets bottom="20" left="10" right="10" top="0"/></padding>

            <VBox alignment="CENTER"
                  style="-fx-background-color: #0F2540; -fx-padding: 15 10 15 10;">
                <Label text="Mi"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="CCobro"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #F39C12;"/>
                <Label text="Sistema de Cuentas"
                       style="-fx-font-size: 9; -fx-text-fill: #AED6F1; -fx-wrap-text: true;"/>
            </VBox>

            <Label fx:id="lblUsuario"
                   style="-fx-text-fill: #AED6F1; -fx-font-size: 10;
                          -fx-wrap-text: true; -fx-padding: 5 0 0 5;"/>

            <Separator style="-fx-background-color: #4A7AAC;"/>

            <Button text="🏠  Inicio"
                    onAction="#handleInicio" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"/>
            <Button fx:id="btnCrearCuenta" text="📄  Crear cuenta"
                    onAction="#handleCrearCuenta" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"/>
            <Button text="📋  Mis cuentas"
                    onAction="#handleMisCuentas" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"/>
            <Button text="👥  Beneficiarios"
                    onAction="#handleBeneficiarios" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"/>
            <Button text="📊  Reportes"
                    onAction="#handleReportes" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"/>
            <Button text="⚙️  Configuración"
                    onAction="#handleConfiguracion" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"/>
            <Button fx:id="btnAdmin" text="🔧  Administrador"
                    onAction="#handleAdmin" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #F39C12;
                           -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"/>
            <Button fx:id="btnRevisor" text="🔍  Revisor"
                    onAction="#handleRevisor" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #AED6F1;
                           -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"/>

            <Separator style="-fx-background-color: #4A7AAC;"/>

            <StackPane>
                <Button text="🔔  Notificaciones"
                        onAction="#verNotificaciones" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: white;
                               -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"/>
                <Label fx:id="lblBadge" visible="false"
                       style="-fx-background-color: #E74C3C; -fx-text-fill: white;
                              -fx-background-radius: 10; -fx-padding: 1 5 1 5;
                              -fx-font-size: 10; -fx-font-weight: bold;"
                       StackPane.alignment="TOP_RIGHT"/>
            </StackPane>

            <Separator style="-fx-background-color: #4A7AAC;"/>

            <Button text="🚪  Cerrar sesión"
                    onAction="#cerrarSesion" maxWidth="Infinity"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white;
                           -fx-cursor: hand;"/>
        </VBox>
    </left>

    <top>
        <HBox spacing="10.0"
              style="-fx-background-color: #F4F6F9; -fx-border-color: #DDE;
                     -fx-border-width: 0 0 1 0;">
            <padding><Insets bottom="8" left="15" right="10" top="8"/></padding>
            <Label text="MiCCobro"
                   style="-fx-font-weight: bold; -fx-text-fill: #1A3A5C; -fx-font-size: 14;"/>
            <Label text="— Sistema de Cuentas de Cobro"
                   style="-fx-text-fill: #7F8C8D; -fx-font-size: 12;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnNuevaCuenta" text="+ Nueva cuenta"
                    onAction="#abrirFormulario"
                    style="-fx-background-color: #27AE60; -fx-text-fill: white;
                           -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10.0">
            <padding><Insets bottom="10" left="15" right="15" top="10"/></padding>
            <Label fx:id="lblRegistros" text="" style="-fx-text-fill: gray;"/>
        </VBox>
    </center>
</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="500.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cuentasdecobro.VistaPrincipalController">
    <left>
        <VBox minWidth="140.0" spacing="12.0">
            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/></padding>
            <children>
                <Label style="-fx-font-weight: bold;" text="Sistema de cuentas de cobro"/>
                <Button fx:id="btnInicio" text="Inicio" onAction="#handleInicio" maxWidth="Infinity"/>
                <Button fx:id="btnCrearCuenta" text="Crear cuenta" onAction="#handleCrearCuenta" maxWidth="Infinity"/>
                <Button fx:id="btnMisCuentas" text="Mis cuentas" onAction="#handleMisCuentas" maxWidth="Infinity"/>
                <Button fx:id="btnBeneficiarios" text="Beneficiarios" onAction="#handleBeneficiarios" maxWidth="Infinity"/>
                <Button fx:id="btnReportes" text="Reportes" onAction="#handleReportes" maxWidth="Infinity"/>
                <Button fx:id="btnConfiguracion" text="Configuración" onAction="#handleConfiguracion" maxWidth="Infinity"/>
                <Button fx:id="btnCerrarSesion" text="Cerrar sesión" onAction="#cerrarSesion" maxWidth="Infinity"/>
            </children>
        </VBox>
    </left>
    <top>
        <HBox spacing="10.0">
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>
            <children>
                <Label text="Listado de cuentas de cobro" style="-fx-font-weight: bold;"/>
                <TextField fx:id="txtBuscar" promptText="Buscar por número o nombre"/>
                <ComboBox fx:id="cmbEstado"/>
                <DatePicker fx:id="dpDesde"/>
                <DatePicker fx:id="dpHasta"/>
                <Button fx:id="btnBuscar" text="Buscar" onAction="#filtrarCuentas"/>
                <Button fx:id="btnNuevaCuenta" text="Nueva cuenta" onAction="#abrirFormulario"/>
            </children>
        </HBox>
    </top>
    <center>
        <VBox spacing="10.0">
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>
            <children>
                <TableView fx:id="tblCuentas">
                    <columns>
                        <TableColumn text="Número"/>
                        <TableColumn text="Funcionario"/>
                        <TableColumn text="Entidad"/>
                        <TableColumn text="Fecha"/>
                        <TableColumn text="Valor"/>
                        <TableColumn text="Estado"/>
                    </columns>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <children>
                        <Label fx:id="lblRegistros" text="Mostrando registros"/>
                        <Button text="Anterior"/>
                        <Button text="Siguiente"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>